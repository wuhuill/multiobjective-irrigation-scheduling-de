clear;
clc;
for i = 1:3
    for j = 1:3
        
        filePath1 = sprintf('result_%d_%d.mat', i, j);
        result = load(filePath1);
        
        [a_sorted, idx] = sort(result.pareto.(:,1), 'descend');  % 객뒤寧죗슉埼탤埼
        myStruct.a = myStruct.a(idx, :);  % 路劤탤죗 a
        myStruct.b = myStruct.b(idx);  % 路劤탤죗 b
        
    end
end
